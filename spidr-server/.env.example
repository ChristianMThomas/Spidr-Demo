# ═══════════════════════════════════════════════════════════════════
#  SPIDR SERVER — Environment Configuration
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# Local MongoDB (run: mongod)
MONGO_URI=mongodb://localhost:27017/spidr
# MongoDB Atlas (cloud):
MONGO_URI=mongodb+srv://spidradmin:UTOAOGWyCWroFBtz@spidr.kj4ddcy.mongodb.net/?appName=Spidr

# ── Redis (optional — OTP falls back to in-memory if not set) ────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=f8a2c9e1d4b7f3a6c0e5d8b2f1a4c7e0d3b6f9a2c5e8d1b4f7a0c3e6d9b2f5a8
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────
# Development: leave as-is (any localhost port is allowed)
CLIENT_ORIGIN=http://localhost:5173
# Production: CLIENT_ORIGIN=https://spidr.yourdomain.com

# ── File Storage ──────────────────────────────────────────────────────
# Option A: Azure Blob Storage (production)
# AZURE_STORAGE_CONN=DefaultEndpointsProtocol=https;AccountName=XXX;AccountKey=XXX;EndpointSuffix=core.windows.net
# AZURE_CONTAINER_NAME=spidr-media

# Option B: Local filesystem (dev default — files saved to /uploads folder)
# No config needed — used automatically when Azure is not configured.

# ── AI / LLM ──────────────────────────────────────────────────────────
# At least one AI key enables AI features (hashtag suggestions, bot responses, etc.)
# The OTP code is always printed to console when no email is set, so you can test without AI too.

# Option 1: OpenAI (recommended — uses gpt-4o-mini)
OPENAI_API_KEY=sk-...your-openai-key-here...

# Option 2: Anthropic Claude (fallback if no OpenAI key — uses claude-3-haiku)
# ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...

# ── Email / 2FA OTP ───────────────────────────────────────────────────
# For Gmail: generate an App Password at myaccount.google.com/apppasswords
# If not set: OTP codes are printed to the server console for dev testing.
# EMAIL_SERVICE=gmail
# EMAIL_USER=youremail@gmail.com
# EMAIL_PASS=your-16-char-app-password

# For Resend (recommended for production): set EMAIL_SERVICE=resend
# EMAIL_SERVICE=resend
# EMAIL_USER=noreply@spidr.yourdomain.com
# EMAIL_PASS=re_your_resend_api_key

# ── Spotify API (optional — for music search in THE WEB) ──────────────────────
# Create app at developer.spotify.com, use Client Credentials flow
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Production CORS ────────────────────────────────────────────────────────────
# Your deployed frontend domain (set when deploying to Render/Railway/Azure)
# CLIENT_ORIGIN=https://spidr.yourdomain.com
# CLIENT_ORIGINS_EXTRA=https://app.spidr.io,https://www.spidr.io

# ── Public server URL (for file upload URLs in production) ─────────────────────
# SERVER_URL=https://spidr-api.yourdomain.com
