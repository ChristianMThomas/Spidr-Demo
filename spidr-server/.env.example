# ═══════════════════════════════════════════════════════════════════
#  SPIDR SERVER — Environment Configuration
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# Local MongoDB (run: mongod)
MONGO_URI=mongodb://localhost:27017/spidr
# MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=Spidr

# ── Redis (optional — OTP falls back to in-memory if not set) ────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-output-of--node-e-console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────
# Development: leave as-is (any localhost port is allowed)
CLIENT_ORIGIN=http://localhost:5173
# Production: CLIENT_ORIGIN=https://spidr.yourdomain.com

# ── File Storage — Cloudflare R2 ─────────────────────────────────────
# Production: create a bucket at dash.cloudflare.com → R2
# Enable public access on the bucket, generate an API token (Object Read & Write)
# Leave all R2_ vars unset in dev — files will save to local /uploads folder instead.
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=spidr-media
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── AI / LLM ──────────────────────────────────────────────────────────
# At least one AI key enables AI features (hashtag suggestions, bot responses, etc.)
# The OTP code is always printed to console when no email is set, so you can test without AI too.

# Option 1: OpenAI (recommended — uses gpt-4o-mini)
OPENAI_API_KEY=sk-...your-openai-key-here...

# Option 2: Anthropic Claude (fallback if no OpenAI key — uses claude-3-haiku)
# ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...

# ── Email / 2FA OTP ───────────────────────────────────────────────────
# For Gmail: generate an App Password at myaccount.google.com/apppasswords
# If not set: OTP codes are printed to the server console for dev testing.
# EMAIL_SERVICE=gmail
# EMAIL_USER=youremail@gmail.com
# EMAIL_PASS=your-16-char-app-password

# For Resend (recommended for production): set EMAIL_SERVICE=resend
# EMAIL_SERVICE=resend
# EMAIL_USER=noreply@spidr.yourdomain.com
# EMAIL_PASS=re_your_resend_api_key

# ── Spotify API (optional — for music search in THE WEB) ──────────────────────
# Create app at developer.spotify.com, use Client Credentials flow
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Production CORS ────────────────────────────────────────────────────────────
# Your deployed frontend domain (set when deploying to Render/Railway/Azure)
# CLIENT_ORIGIN=https://spidr.yourdomain.com
# CLIENT_ORIGINS_EXTRA=https://app.spidr.io,https://www.spidr.io

# ── Public server URL (for file upload URLs in production) ─────────────────────
# SERVER_URL=https://spidr-api.yourdomain.com

# ── Voice TURN server (WebRTC cross-network relay) ────────────────────────────
# Without TURN, ~25% of users (symmetric NAT) can't connect across networks.
# Leave unset to use a free public TURN fallback (openrelay.metered.ca) — fine
# for beta, but rate-limited and occasionally down. For production, provide your
# own (coturn, Cloudflare Calls, Twilio, Metered, etc).
# TURN_URL may be comma-separated for multiple transports.
# TURN_URL=turn:your-turn-host:3478,turns:your-turn-host:5349?transport=tcp
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_credential
